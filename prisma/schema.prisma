generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String?
  name         String
  role         String    @default("customer") // customer, technician, admin
  languagePref String    @default("en")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customer     Customer?
  technician   Technician?
}

model Customer {
  id       String  @id @default(cuid())
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id])
  address  String?
  city     String?
  county   String?
  zip      String?
  notes    String?
  jobs     Job[]
  reviews  Review[]
}

model Technician {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id])
  skills       String? // JSON array stored as string
  zones        String? // JSON array stored as string
  availability String? // JSON
  rating       Float   @default(0)
  jobs         Job[]
}

model Job {
  id           String    @id @default(cuid())
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id])
  serviceType  String    // washer, dryer, range, dishwasher, refrigerator, ac, plumbing
  appliance    String?
  status       String    @default("new") // new, assigned, in_progress, completed, invoiced, cancelled
  description  String?
  customerName String?
  customerPhone String?
  customerEmail String?
  customerAddress String?
  photos       String?   // JSON array of URLs
  scheduledAt  DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoice      Invoice?
  review       Review?
}

model Invoice {
  id            String   @id @default(cuid())
  jobId         String   @unique
  job           Job      @relation(fields: [jobId], references: [id])
  items         String?  // JSON array
  subtotal      Float    @default(0)
  tax           Float    @default(0)
  total         Float    @default(0)
  paymentMethod String?  // stripe, cash, check
  paymentStatus String   @default("pending") // pending, paid, overdue
  stripeId      String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  jobId      String   @unique
  job        Job      @relation(fields: [jobId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model ServiceRequest {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String?
  address      String
  city         String?
  zip          String?
  serviceType  String
  description  String?
  preferredDate String?
  preferredTime String?
  photos       String?
  status       String   @default("pending") // pending, contacted, converted, cancelled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  discountType String  @default("flat") // flat, percentage
  amount      Float
  active      Boolean  @default(true)
  usageLimit  Int?
  usageCount  Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}
